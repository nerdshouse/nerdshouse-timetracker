// Time Tracker & Issue Tracker - Prisma Schema
// Use SQLite for dev (file:./dev.db). For production, switch datasource to postgresql.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  DEVELOPER
  CLIENT
}

enum ProjectStatus {
  active
  on_hold
  completed
}

enum TaskStatus {
  todo
  in_progress
  review
  done
}

enum TaskPriority {
  low
  medium
  high
  critical
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String?  // null for legacy/seed; set for password login
  role         UserRole
  avatar       String?
  createdAt    DateTime @default(now())

  client              Client?           @relation("ClientUser")
  clientTeamMemberships ClientTeamMember[]
  assignedTasks       Task[]            @relation("AssignedTasks")
  createdTasks        Task[]            @relation("CreatedTasks")
  timeLogs            TimeLog[]
  activityLogs        ActivityLog[]
  activeTimers        ActiveTimer[]
  auditLogs           AuditLog[]

  @@map("users")
}

model Client {
  id           String   @id @default(cuid())
  name         String
  contactEmail String
  userId       String   @unique
  createdAt    DateTime @default(now())

  user         User               @relation("ClientUser", fields: [userId], references: [id], onDelete: Cascade)
  projects     Project[]
  teamMembers  ClientTeamMember[]
  clientHoursTopUps ClientHoursTopUp[]

  @@map("clients")
}

model ClientHoursTopUp {
  id          String    @id @default(cuid())
  clientId    String
  hours       Float
  ratePerHour Float
  boughtDate  DateTime?
  createdAt   DateTime  @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_hours_top_ups")
}

model ClientTeamMember {
  id        String   @id @default(cuid())
  clientId  String
  userId    String   @unique
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("client_team_members")
}

model Project {
  id                String        @id @default(cuid())
  name              String
  description       String?
  status            ProjectStatus @default(active)
  clientId          String
  hourlyRate        Float         // Rs. - visible to Owner + Client only
  totalHoursBought  Float         // visible to Owner + Client only
  boughtDate        DateTime?     // when hours were purchased
  createdAt         DateTime      @default(now())

  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks      Task[]
  hoursTopUps HoursTopUp[]

  @@map("projects")
}

model HoursTopUp {
  id         String    @id @default(cuid())
  projectId  String
  hours      Float
  ratePerHour Float    // Rs. per hour at which this batch was bought
  boughtDate DateTime?
  createdAt  DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("hours_top_ups")
}

model Task {
  id          String       @id @default(cuid())
  projectId   String
  title       String
  description String?
  status      TaskStatus   @default(todo)
  priority    TaskPriority @default(medium)
  assignedToId String      // Developer
  createdById  String
  createdAt   DateTime    @default(now())

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedTo User        @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: Cascade)
  createdBy  User        @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: Cascade)
  timeLogs   TimeLog[]
  activeTimers ActiveTimer[]

  @@map("tasks")
}

model TimeLog {
  id         String    @id @default(cuid())
  taskId     String
  userId     String
  startTime  DateTime
  endTime    DateTime
  durationMs Int       // stored in milliseconds
  entryType  String    @default("realtime") // "realtime" | "manual" | "duration_only"
  note       String?
  isShared   Boolean   @default(false)
  isLocked   Boolean   @default(false)
  lockedAt   DateTime?
  lockedById String?

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("time_logs")
}

model ActiveTimer {
  id        String   @id @default(cuid())
  taskId    String   @unique // one active timer per task
  userId    String
  startTime DateTime
  elapsedMs Int      @default(0) // for pause: accumulated time before pause

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("active_timers")
}

model ActivityLog {
  id        String   @id @default(cuid())
  type      String   // e.g. "project_created", "task_assigned", "timer_started"
  userId    String
  entityId  String   // id of project/task/etc
  entityType String  // "project" | "task" | "timer" | "team"
  message   String
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String   // "create" | "update" | "delete" | "lock" | "unlock"
  entityType String   // "time_log" | "project" | "task" | "user" | etc
  entityId   String
  userId     String
  details    String?  // JSON or text summary
  timestamp  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("settings")
}
